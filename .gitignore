# =============================================================================
# Still — monorepo .gitignore  (mobile: Expo/React Native · server: Go)
# Patterns without a leading slash match in every directory.
# =============================================================================

# ------------------------------------------------------------------ Secrets --
# Never commit local env files or credentials. Templates (*.example) are kept.
.env
.env.*
!.env.example
!**/.env.example


package-lock.json

# Firebase / Google service-account keys
service-account*.json
*serviceAccount*.json
*-service-account.json

# Firebase client config (per-project; add locally, see FIREBASE_SETUP.md)
google-services.json
GoogleService-Info.plist

# Signing material / certificates
*.keystore
*.jks
*.p8
*.p12
*.pem
*.mobileprovision
*.cer
*.certSigningRequest

# --------------------------------------------------------------------- Node --
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/versions
npm-debug.*
yarn-debug.*
yarn-error.*
.pnpm-debug.log*
.npm/
.eslintcache

# ------------------------------------------------------- Expo / React Native --
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts
.metro-health-check*
*.jsbundle

# Native projects are generated by `expo prebuild` (Continuous Native Generation)
/mobile/ios/
/mobile/android/

# Fastlane / native build leftovers
**/ios/Pods/
**/ios/build/
**/*.xcworkspace/xcuserdata/
**/android/.gradle/
**/android/app/build/
**/android/build/
**/android/local.properties

# ----------------------------------------------------------------------- Go --
# Compiled binaries / build output
/server/bin/
/server/dist/
still-server
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test / profiling / coverage
*.test
*.out
*.prof
coverage.txt
coverage.html

# Go workspace file (usually machine-local)
go.work
go.work.sum

# --------------------------------------------------------- Logs & runtime ----
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock
.pm2/

# TypeScript build info
*.tsbuildinfo

# ------------------------------------------------------------ Editors / IDE --
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml
*.swp
*.swo
*~
.history/

# --------------------------------------------------------------------- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ------------------------------------------------------------------- Misc -----
tmp/
temp/
.cache/
*.bak
*.orig
